generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  OTHER
}

enum RecipeVisibility {
  PUBLIC
  FRIENDS
  PRIVATE
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  username           String              @unique
  displayName        String
  passwordHash       String
  bio                String?
  isVerified         Boolean             @default(false)
  isPrivate          Boolean             @default(false)
  dailyCalorieGoal   Int                 @default(2200)
  proteinGoal        Int                 @default(160)
  carbsGoal          Int                 @default(220)
  fatGoal            Int                 @default(70)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  verificationTokens VerificationToken[]
  foodLogs           FoodLog[]
  recipes            Recipe[]
  recipeLikes        RecipeLike[]
  recipeSaves        RecipeSave[]
  recipeComments     RecipeComment[]
  sentRequests       FriendRequest[]     @relation("SentFriendRequests")
  receivedRequests   FriendRequest[]     @relation("ReceivedFriendRequests")
  friendshipsA       Friendship[]        @relation("FriendshipA")
  friendshipsB       Friendship[]        @relation("FriendshipB")

  @@index([isVerified])
  @@index([username])
  @@index([email])
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
  @@index([expiresAt])
}

model FoodLog {
  id          String   @id @default(cuid())
  userId      String
  foodName    String
  calories    Int
  protein     Int
  carbs       Int
  fat         Int
  mealType    MealType
  servingSize String?
  notes       String?
  logDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, logDate])
  @@index([mealType])
}

model Recipe {
  id           String           @id @default(cuid())
  userId       String
  title        String
  description  String
  imageUrl     String?
  ingredients  String
  instructions String
  calories     Int
  protein      Int
  carbs        Int
  fat          Int
  tags         String[]
  visibility   RecipeVisibility @default(PUBLIC)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes        RecipeLike[]
  saves        RecipeSave[]
  comments     RecipeComment[]

  @@index([userId])
  @@index([visibility])
  @@index([createdAt])
  @@index([calories])
  @@index([protein])
}

model RecipeLike {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([recipeId])
}

model RecipeSave {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([recipeId])
}

model RecipeComment {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([userId])
}

model FriendRequest {
  id         String              @id @default(cuid())
  senderId   String
  receiverId String
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  sender     User                @relation("SentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User                @relation("ReceivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId, status])
  @@index([receiverId, status])
  @@index([senderId, status])
}

model Friendship {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  userA     User     @relation("FriendshipA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("FriendshipB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}
